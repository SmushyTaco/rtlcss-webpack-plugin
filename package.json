{
  "name": "@smushytaco/rtlcss-webpack-plugin",
  "version": "1.0.5",
  "type": "module",
  "license": "MIT",
  "private": false,
  "author": {
    "name": "SmushyTaco",
    "email": "personal@nikanradan.com"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.12.0",
    "npm": ">=8.19.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SmushyTaco/rtlcss-webpack-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/SmushyTaco/rtlcss-webpack-plugin/issues"
  },
  "scripts": {
    "clean": "del-cli dist",
    "build:types": "npx tsc --emitDeclarationOnly",
    "build": "npm run clean && npx tsx esbuild.ts && npm run build:types",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/rtlcss": "^3.5.4",
    "@eslint/js": "^9.17.0",
    "@smushytaco/versionchecker": "^1.0.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "typescript-eslint": "^8.18.2",
    "tsx": "^4.19.2",
    "esbuild": "^0.24.2",
    "globals": "^15.14.0",
    "del-cli": "^6.0.0",
    "webpack": "^5.97.1"
  },
  "dependencies": {
    "rtlcss": "^4.3.0"
  }
}
