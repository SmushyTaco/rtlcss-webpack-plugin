{
  "name": "@smushytaco/rtlcss-webpack-plugin",
  "version": "1.0.0",
  "license": "MIT",
  "private": false,
  "author": {
    "name": "SmushyTaco",
    "email": "personal@nikanradan.com"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/es6/index.js",
  "types": "dist/es6/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.12.0",
    "npm": ">=8.19.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SmushyTaco/rtlcss-webpack-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/SmushyTaco/rtlcss-webpack-plugin/issues"
  },
  "scripts": {
    "build:es6": "tsc --project tsconfig.json",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build": "npm run build:es6 && npm run build:cjs",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/rtlcss": "^3.5.4",
    "@eslint/js": "^9.17.0",
    "@smushytaco/versionchecker": "^1.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "webpack": "^5.97.1"
  },
  "dependencies": {
    "rtlcss": "^4.3.0"
  },
  "exports": {
    "import": "./dist/es6/index.js",
    "require": "./dist/cjs/index.js"
  }
}
